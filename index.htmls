<html lang="en"><head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rasulbek Rustamov | Senior Paid Social Executive</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;family=Space+Grotesk:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        :root{--primary:#4361ee;--secondary:#f72585;--accent:#4cc9f0;--dark:#070b14;--dark-2:#0d1321;--light:#ffffff;--gray:#8892b0;--success:#00c896;--warning:#ffa500;--gradient-1:linear-gradient(135deg,#4361ee,#4cc9f0);--gradient-2:linear-gradient(135deg,#f72585,#7209b7)}
        html{scroll-behavior:smooth;scroll-padding-top:80px}
        body{font-family:'Inter',system-ui,sans-serif;background:var(--dark);color:var(--light);overflow-x:hidden;line-height:1.6}
        .scroll-progress{position:fixed;top:0;left:0;height:3px;background:var(--gradient-1);z-index:99999;width:0%}
        .cursor-dot{width:8px;height:8px;background:var(--accent);border-radius:50%;position:fixed;pointer-events:none;z-index:99998;transform:translate(-50%,-50%)}
        .cursor-ring{width:35px;height:35px;border:1.5px solid rgba(76,201,240,0.5);border-radius:50%;position:fixed;pointer-events:none;z-index:99997;transition:all .2s ease-out;transform:translate(-50%,-50%)}
        .cursor-ring.hover{width:55px;height:55px;border-color:var(--secondary);background:rgba(247,37,133,0.08)}
        nav{position:fixed;top:0;width:100%;padding:20px 60px;display:flex;justify-content:space-between;align-items:center;z-index:9999;transition:all .3s ease}
        nav.scrolled{background:rgba(7,11,20,0.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);padding:12px 60px;border-bottom:1px solid rgba(255,255,255,0.05);box-shadow:0 5px 30px rgba(0,0,0,0.3)}
        .logo{display:flex;align-items:center;text-decoration:none}
        .logo-box{width:42px;height:42px;border-radius:11px;background:var(--gradient-1);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;transition:all .4s cubic-bezier(0.16,1,0.3,1)}
        .logo-box::before{content:'';position:absolute;inset:0;background:var(--gradient-2);opacity:0;transition:opacity .4s ease}
        .logo:hover .logo-box::before{opacity:1}
        .logo:hover .logo-box{transform:rotate(-5deg) scale(1.08);box-shadow:0 5px 20px rgba(67,97,238,0.4)}
        .logo-text{font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:800;color:white;position:relative;z-index:1}
        .logo-name{font-family:'Space Grotesk',sans-serif;font-size:1.05rem;font-weight:700;color:var(--light);margin-left:12px;transition:color .3s ease}
        .logo-name span{color:var(--gray);font-weight:400}
        .logo:hover .logo-name{color:var(--accent)}
        .nav-links{display:flex;list-style:none;gap:32px;align-items:center}
        .nav-links li a{color:var(--gray);text-decoration:none;font-size:.9rem;font-weight:500;transition:color .3s ease;position:relative;padding:5px 0}
        .nav-links li a:hover,.nav-links li a.active{color:var(--light)}
        .nav-links li a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:var(--gradient-1);transition:width .3s ease}
        .nav-links li a:hover::after,.nav-links li a.active::after{width:100%}
        .nav-cta-btn{padding:10px 22px!important;background:var(--gradient-1)!important;border-radius:8px!important;color:white!important;font-weight:600!important;box-shadow:0 4px 15px rgba(67,97,238,0.3)}
        .nav-cta-btn::after{display:none!important}
        .nav-cta-btn:hover{transform:translateY(-2px)!important;box-shadow:0 8px 25px rgba(67,97,238,0.5)!important}
        .hamburger{display:none;flex-direction:column;gap:6px;cursor:pointer;z-index:10001;padding:5px}
        .hamburger span{width:28px;height:2px;background:var(--light);transition:all .3s ease}
        .hamburger.active span:nth-child(1){transform:rotate(45deg) translate(5px,6px)}
        .hamburger.active span:nth-child(2){opacity:0}
        .hamburger.active span:nth-child(3){transform:rotate(-45deg) translate(6px,-6px)}
        .nav-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9998}
        .nav-overlay.active{display:block}
        #bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;opacity:.5}
        section{position:relative;z-index:1}
        .hero{min-height:100vh;display:flex;align-items:center;padding:120px 10% 80px}
        .hero-content{max-width:680px;width:100%}
        .hero-badge{display:inline-flex;align-items:center;gap:10px;padding:10px 18px;background:rgba(67,97,238,0.08);border:1px solid rgba(67,97,238,0.25);border-radius:50px;font-size:.85rem;color:var(--accent);margin-bottom:30px;opacity:0;animation:fadeInUp .8s ease forwards .2s}
        .hero-badge .dot{width:8px;height:8px;background:var(--success);border-radius:50%;animation:pulse 2s ease infinite}
        .hero-title{font-family:'Space Grotesk',sans-serif;font-size:clamp(2.5rem,5.5vw,4.2rem);font-weight:800;line-height:1.1;margin-bottom:25px;opacity:0;animation:fadeInUp .8s ease forwards .4s;letter-spacing:-1px}
        .hero-title .highlight{background:var(--gradient-2);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .hero-description{font-size:1.1rem;color:var(--gray);line-height:1.8;margin-bottom:40px;max-width:560px;opacity:0;animation:fadeInUp .8s ease forwards .6s}
        .hero-stats{display:flex;gap:45px;margin-bottom:45px;opacity:0;animation:fadeInUp .8s ease forwards .8s}
        .stat-number{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;background:var(--gradient-1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1.2}
        .stat-label{font-size:.82rem;color:var(--gray);margin-top:4px}
        .hero-cta{display:flex;gap:15px;flex-wrap:wrap;opacity:0;animation:fadeInUp .8s ease forwards 1s}
        .btn{padding:14px 30px;border-radius:10px;font-size:.95rem;font-weight:600;text-decoration:none;transition:all .3s ease;display:inline-flex;align-items:center;gap:8px;cursor:pointer;border:none;font-family:'Inter',sans-serif}
        .btn-primary{background:var(--gradient-1);color:white;box-shadow:0 5px 20px rgba(67,97,238,0.3)}
        .btn-primary:hover{transform:translateY(-3px);box-shadow:0 15px 40px rgba(67,97,238,0.4)}
        .btn-secondary{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.15);color:var(--light)}
        .btn-secondary:hover{background:rgba(255,255,255,0.08);border-color:var(--accent);transform:translateY(-3px)}
        .hero-visual{position:absolute;right:8%;top:50%;transform:translateY(-50%);width:420px;height:420px;opacity:0;animation:fadeIn 1.5s ease forwards 1.2s}
        #hero-chart{width:100%;height:100%;display:block}
        .platforms-section{padding:50px 0;border-top:1px solid rgba(255,255,255,0.04);border-bottom:1px solid rgba(255,255,255,0.04);overflow:hidden;background:rgba(13,19,33,0.5)}
        .platforms-label{text-align:center;font-size:.75rem;color:var(--gray);letter-spacing:3px;text-transform:uppercase;margin-bottom:25px}
        .marquee-container{overflow:hidden;width:100%}
        .marquee{display:flex;width:max-content;animation:marquee 35s linear infinite}
        .marquee:hover{animation-play-state:paused}
        .marquee-item{display:flex;align-items:center;gap:10px;padding:12px 24px;margin:0 8px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:10px;white-space:nowrap;font-weight:500;font-size:.88rem;color:var(--gray);transition:all .3s ease;flex-shrink:0}
        .marquee-item:hover{border-color:var(--primary);color:var(--light);background:rgba(67,97,238,0.08)}
        .p-icon{width:24px;height:24px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .p-icon img{width:24px;height:24px;border-radius:4px}
        .about{padding:140px 10%;display:grid;grid-template-columns:1fr 1.2fr;gap:80px;align-items:center}
        .about-left{position:relative}
        .about-image-container{position:relative;width:100%;max-width:380px}
        .about-photo-wrapper{position:relative;width:100%;border-radius:20px;overflow:hidden;box-shadow:0 30px 60px rgba(0,0,0,0.4)}
        .about-photo-wrapper::before{content:'';position:absolute;inset:0;border-radius:20px;padding:3px;background:linear-gradient(135deg,var(--primary),var(--secondary),var(--accent));-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;z-index:2;opacity:.8;transition:opacity .4s ease}
        .about-photo-wrapper:hover::before{opacity:1}
        .about-photo{width:100%;height:auto;display:block;border-radius:20px;transition:all .5s ease;aspect-ratio:3/4;object-fit:cover;object-position:center top}
        .about-photo-wrapper:hover .about-photo{transform:scale(1.03)}
        .about-photo-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(7,11,20,0.7) 100%);border-radius:20px;z-index:1;pointer-events:none}
        .photo-placeholder{width:100%;aspect-ratio:3/4;border-radius:20px;background:linear-gradient(135deg,var(--dark-2),rgba(67,97,238,0.1));display:none;align-items:center;justify-content:center;flex-direction:column;gap:15px;border:2px dashed rgba(67,97,238,0.3)}
        .photo-placeholder .placeholder-text{font-size:.85rem;color:var(--gray);text-align:center;padding:0 20px;line-height:1.6}
        .about-photo.error{display:none}
        .about-photo.error~.photo-placeholder{display:flex}
        .about-float-card{position:absolute;background:rgba(13,19,33,0.95);border:1px solid rgba(255,255,255,0.1);border-radius:14px;padding:14px 18px;backdrop-filter:blur(10px);z-index:3;box-shadow:0 10px 30px rgba(0,0,0,0.3)}
        .afc-budget{bottom:-15px;right:-20px;animation:float 4s ease-in-out infinite}
        .afc-experience{top:30px;right:-30px;animation:float 4s ease-in-out infinite 1s}
        .afc-meta{bottom:70px;left:-20px;animation:float 4s ease-in-out infinite 2s}
        .about-float-card .afc-title{font-size:.62rem;color:var(--gray);text-transform:uppercase;letter-spacing:1px;margin-bottom:2px}
        .about-float-card .afc-value{font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700}
        .afc-budget .afc-value{color:var(--accent)}
        .afc-experience .afc-value{color:var(--success)}
        .afc-meta .afc-value{color:var(--secondary)}
        .about-decoration{position:absolute;width:120px;height:120px;border:2px solid rgba(67,97,238,0.12);border-radius:20px;top:-15px;left:-15px;transform:rotate(-8deg);z-index:0}
        .about-glow{position:absolute;width:200px;height:200px;background:radial-gradient(circle,rgba(67,97,238,0.15),transparent 70%);border-radius:50%;top:-50px;right:-50px;z-index:0;pointer-events:none}
        .section-label{font-size:.82rem;color:var(--accent);letter-spacing:3px;text-transform:uppercase;font-weight:600;margin-bottom:15px}
        .section-title{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;margin-bottom:25px;line-height:1.2}
        .about-text{color:var(--gray);line-height:1.9;margin-bottom:15px;font-size:.98rem}
        .about-details{display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-top:30px}
        .about-detail{padding:18px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:12px;transition:all .3s ease}
        .about-detail:hover{border-color:rgba(67,97,238,0.2);background:rgba(67,97,238,0.03)}
        .about-detail-label{font-size:.72rem;color:var(--gray);margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
        .about-detail-value{font-weight:600;font-size:.92rem}
        .languages{display:flex;gap:12px;margin-top:25px;flex-wrap:wrap}
        .lang-badge{padding:7px 14px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.08);border-radius:8px;font-size:.82rem;color:var(--gray);display:flex;align-items:center;gap:8px}
        .lang-level{width:6px;height:6px;border-radius:50%}
        .lang-level.native{background:var(--success)}
        .lang-level.professional{background:var(--accent)}
        .lang-level.elementary{background:var(--warning)}
        .expertise{padding:140px 10%;background:var(--dark-2)}
        .expertise-header{text-align:center;margin-bottom:70px}
        .section-subtitle{color:var(--gray);font-size:1rem;max-width:500px;margin:10px auto 0}
        .expertise-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:25px}
        .expertise-card{padding:35px;background:rgba(255,255,255,0.015);border:1px solid rgba(255,255,255,0.06);border-radius:18px;transition:all .4s ease;position:relative;overflow:hidden}
        .expertise-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--gradient-1);transform:scaleX(0);transform-origin:left;transition:transform .4s ease}
        .expertise-card:hover::before{transform:scaleX(1)}
        .expertise-card:hover{border-color:rgba(67,97,238,0.2);transform:translateY(-5px);box-shadow:0 20px 50px rgba(0,0,0,0.2)}
        .expertise-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;font-size:1.5rem}
        .ei-1{background:rgba(67,97,238,0.12)}.ei-2{background:rgba(247,37,133,0.12)}.ei-3{background:rgba(76,201,240,0.12)}.ei-4{background:rgba(0,200,150,0.12)}.ei-5{background:rgba(255,165,0,0.12)}.ei-6{background:rgba(114,9,183,0.12)}
        .expertise-title{font-size:1.15rem;font-weight:700;margin-bottom:10px}
        .expertise-desc{color:var(--gray);font-size:.88rem;line-height:1.7}
        .metrics-section{padding:140px 10%}
        .metrics-header{text-align:center;margin-bottom:60px}
        .viz-container{display:grid;grid-template-columns:1.8fr 1fr;gap:30px;align-items:start}
        .chart-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:18px;padding:35px}
        .chart-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:25px;flex-wrap:wrap;gap:10px}
        .chart-card-title{font-size:.95rem;font-weight:600;display:flex;align-items:center;gap:10px}
        .live-dot{width:8px;height:8px;border-radius:50%;background:var(--success);animation:pulse 2s ease infinite}
        #budget-chart{width:100%;height:220px;display:block}
        .metrics-stack{display:flex;flex-direction:column;gap:15px}
        .metric-card{padding:22px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:14px;transition:all .3s ease}
        .metric-card:hover{border-color:rgba(67,97,238,0.25);transform:translateX(5px)}
        .metric-label{font-size:.73rem;color:var(--gray);margin-bottom:6px;text-transform:uppercase;letter-spacing:1px}
        .metric-value{font-family:'Space Grotesk',sans-serif;font-size:1.6rem;font-weight:700}
        .metric-change{font-size:.76rem;color:var(--success);margin-top:4px}
        .metric-change.neutral{color:var(--gray)}
        .experience{padding:140px 10%;background:var(--dark-2)}
        .experience-header{text-align:center;margin-bottom:70px}
        .timeline{max-width:850px;margin:0 auto;position:relative}
        .timeline::before{content:'';position:absolute;left:28px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--primary),var(--secondary),var(--accent),var(--success))}
        .timeline-item{position:relative;padding-left:75px;margin-bottom:40px;opacity:0;transform:translateX(-20px);transition:all .6s cubic-bezier(0.16,1,0.3,1)}
        .timeline-item.visible{opacity:1;transform:translateX(0)}
        .timeline-item:last-child{margin-bottom:0}
        .timeline-dot{position:absolute;left:20px;top:28px;width:18px;height:18px;border-radius:50%;background:var(--dark-2);border:3px solid var(--primary);z-index:1}
        .timeline-item:first-child .timeline-dot{background:var(--primary);box-shadow:0 0 20px rgba(67,97,238,0.5)}
        .timeline-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:28px;transition:all .3s ease}
        .timeline-card:hover{border-color:rgba(67,97,238,0.2)}
        .timeline-date{font-size:.76rem;color:var(--accent);font-weight:600;letter-spacing:1px;margin-bottom:8px}
        .timeline-role{font-size:1.2rem;font-weight:700;margin-bottom:5px}
        .timeline-company{font-size:.95rem;color:var(--secondary);font-weight:600;margin-bottom:4px}
        .timeline-location{font-size:.82rem;color:var(--gray);margin-bottom:15px}
        .timeline-details{list-style:none}
        .timeline-details li{color:var(--gray);font-size:.86rem;line-height:1.8;padding-left:18px;position:relative}
        .timeline-details li::before{content:'▹';position:absolute;left:0;color:var(--accent)}
        .timeline-tools{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
        .tool-tag{padding:5px 12px;background:rgba(67,97,238,0.1);border-radius:6px;font-size:.75rem;color:var(--accent);font-weight:500}
        .certifications{padding:140px 10%}
        .certs-header{text-align:center;margin-bottom:60px}
        .certs-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;max-width:1100px;margin:0 auto}
        .cert-card{padding:24px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:14px;display:flex;align-items:flex-start;gap:16px;transition:all .3s ease}
        .cert-card:hover{border-color:rgba(67,97,238,0.25);transform:translateY(-4px);box-shadow:0 15px 40px rgba(0,0,0,0.2)}
        .cert-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.5rem}
        .cert-info h4{font-size:.92rem;font-weight:600;margin-bottom:5px;line-height:1.4}
        .cert-info p{font-size:.8rem;color:var(--gray)}
        .cert-badge{display:inline-flex;align-items:center;gap:5px;margin-top:8px;padding:3px 10px;background:rgba(0,200,150,0.1);border-radius:5px;font-size:.7rem;color:var(--success);font-weight:600}
        .cert-card.award{border-color:rgba(255,165,0,0.25);background:rgba(255,165,0,0.03)}
        .cert-card.award:hover{border-color:rgba(255,165,0,0.5)}
        .contact{padding:140px 10%;background:var(--dark-2);text-align:center}
        .contact-description{color:var(--gray);font-size:1.05rem;max-width:480px;margin:0 auto 45px;line-height:1.8}
        .contact-email-link{display:inline-block;margin-bottom:50px;text-decoration:none}
        .contact-email{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.3rem,2.5vw,2.2rem);font-weight:700;background:var(--gradient-1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .contact-email-link::after{content:'';display:block;width:0;height:2px;background:var(--gradient-1);transition:width .3s ease;margin-top:5px}
        .contact-email-link:hover::after{width:100%}
        .social-links{display:flex;justify-content:center;gap:18px}
        .social-link{width:52px;height:52px;border-radius:14px;border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;text-decoration:none;color:var(--gray);transition:all .3s ease}
        .social-link:hover{border-color:var(--primary);color:var(--light);background:rgba(67,97,238,0.1);transform:translateY(-5px)}
        .social-link svg{width:20px;height:20px;fill:currentColor}
        footer{position:relative;z-index:1;padding:30px 10%;border-top:1px solid rgba(255,255,255,0.04);display:flex;justify-content:space-between;align-items:center;color:var(--gray);font-size:.82rem}
        footer a{color:var(--accent);text-decoration:none}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
        @keyframes fadeIn{from{opacity:0}to{opacity:1}}
        @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.5)}}
        @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
        @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
        .reveal{opacity:0;transform:translateY(40px);transition:all .8s cubic-bezier(0.16,1,0.3,1)}
        .reveal.visible{opacity:1;transform:translateY(0)}
        .reveal-delay-1{transition-delay:.1s}.reveal-delay-2{transition-delay:.2s}.reveal-delay-3{transition-delay:.3s}
        @media(max-width:1100px){.hero-visual{display:none}}
        @media(max-width:968px){.about{grid-template-columns:1fr;gap:60px}.about-left{display:flex;justify-content:center}.about-image-container{max-width:300px}.viz-container{grid-template-columns:1fr}}
        @media(max-width:768px){nav{padding:15px 25px}nav.scrolled{padding:12px 25px}.logo-name{display:none}.nav-links{position:fixed;top:0;right:-100%;width:75%;max-width:320px;height:100vh;background:rgba(13,19,33,0.98);backdrop-filter:blur(20px);flex-direction:column;justify-content:center;align-items:center;gap:25px;transition:right .4s cubic-bezier(0.16,1,0.3,1);border-left:1px solid rgba(255,255,255,0.05)}.nav-links.active{right:0}.hamburger{display:flex}section{padding-left:6%!important;padding-right:6%!important}.hero{padding-top:100px!important}.hero-stats{gap:25px}.stat-number{font-size:1.5rem}.about-details{grid-template-columns:1fr}.expertise-grid{grid-template-columns:1fr}.certs-grid{grid-template-columns:1fr}.timeline::before{left:14px}.timeline-item{padding-left:50px}.timeline-dot{left:6px;width:16px;height:16px}.timeline-item:first-child .timeline-dot{left:5px}.cursor-dot,.cursor-ring{display:none!important}footer{flex-direction:column;gap:10px;text-align:center}.afc-experience,.afc-meta{display:none}}
        @media(max-width:480px){.hero-stats{flex-wrap:wrap}.hero-cta{flex-direction:column}.btn{justify-content:center;width:100%}.languages{flex-direction:column}.about-float-card{display:none}}
    </style>
</head>
<body>
    <div class="scroll-progress" id="scrollProgress"></div>
    <div class="cursor-dot" id="cursorDot"></div>
    <div class="cursor-ring" id="cursorRing"></div>
    <div class="nav-overlay" id="navOverlay"></div>
    <canvas id="bg-canvas"></canvas>

    <nav id="navbar">
        <a href="#home" class="logo"><div class="logo-box"><span class="logo-text">RR</span></div><span class="logo-name">Rasulbek <span>Rustamov</span></span></a>
        <ul class="nav-links" id="navLinks">
            <li><a href="#home" class="nav-link active">Home</a></li>
            <li><a href="#about" class="nav-link">About</a></li>
            <li><a href="#expertise" class="nav-link">Expertise</a></li>
            <li><a href="#experience" class="nav-link">Experience</a></li>
            <li><a href="#certifications" class="nav-link">Certifications</a></li>
            <li><a href="#contact" class="nav-link nav-cta-btn">Contact</a></li>
        </ul>
        <div class="hamburger" id="hamburger"><span></span><span></span><span></span></div>
    </nav>

    <section class="hero" id="home">
        <div class="hero-content">
            <div class="hero-badge"><span class="dot"></span> Senior Paid Social Executive @ WPP Media</div>
            <h1 class="hero-title">Rasulbek<br><span class="highlight">Rustamov</span></h1>
            <p class="hero-description">4+ years driving performance through data-driven paid social strategies across Meta, Snapchat, Pinterest &amp; more. Managing $350K–$550K monthly advertising budgets across international markets.</p>
            <div class="hero-stats">
                <div class="stat"><div class="stat-number">4+</div><div class="stat-label">Years Experience</div></div>
                <div class="stat"><div class="stat-number">$550K+</div><div class="stat-label">Monthly Budget</div></div>
                <div class="stat"><div class="stat-number">6+</div><div class="stat-label">Ad Platforms</div></div>
            </div>
            <div class="hero-cta">
                <a href="#contact" class="btn btn-primary">Let's Connect <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
                <a href="#experience" class="btn btn-secondary">View Experience</a>
            </div>
        </div>
        <div class="hero-visual"><canvas id="hero-chart"></canvas></div>
    </section>

    <section class="platforms-section">
        <p class="platforms-label">Platforms &amp; Tools I Work With</p>
        <div class="marquee-container"><div class="marquee">
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/meta/0081FB" alt=""></span> Meta Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/instagram/E4405F" alt=""></span> Instagram</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/snapchat/FFFC00" alt=""></span> Snapchat</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/pinterest/BD081C" alt=""></span> Pinterest</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/reddit/FF4500" alt=""></span> Reddit Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/googleanalytics/E37400" alt=""></span> Analytics</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/googleads/4285F4" alt=""></span> Google Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/tiktok/ffffff" alt=""></span> TikTok Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/x/ffffff" alt=""></span> X (Twitter)</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://img.icons8.com/color/48/tableau-software.png" alt=""></span> Tableau</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/meta/0081FB" alt=""></span> Meta Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/instagram/E4405F" alt=""></span> Instagram</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/snapchat/FFFC00" alt=""></span> Snapchat</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/pinterest/BD081C" alt=""></span> Pinterest</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/reddit/FF4500" alt=""></span> Reddit Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/googleanalytics/E37400" alt=""></span> Analytics</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/googleads/4285F4" alt=""></span> Google Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/tiktok/ffffff" alt=""></span> TikTok Ads</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://cdn.simpleicons.org/x/ffffff" alt=""></span> X (Twitter)</div>
            <div class="marquee-item"><span class="p-icon"><img src="https://img.icons8.com/color/48/tableau-software.png" alt=""></span> Tableau</div>
        </div></div>
    </section>

    <section class="about" id="about">
        <div class="about-left reveal">
            <div class="about-image-container">
                <div class="about-decoration"></div><div class="about-glow"></div>
                <div class="about-photo-wrapper">
                    <img src="profile.jpg" alt="Rasulbek Rustamov" class="about-photo" onerror="this.classList.add('error')">
                    <div class="about-photo-overlay"></div>
                    <div class="photo-placeholder"><div class="placeholder-text">📷<br><br>Rename your photo to<br><strong>profile.jpg</strong><br>and place in same folder</div></div>
                </div>
                <div class="about-float-card afc-budget"><div class="afc-title">Monthly Budget</div><div class="afc-value">$550K+</div></div>
                <div class="about-float-card afc-experience"><div class="afc-title">Experience</div><div class="afc-value">4+ Years</div></div>
                <div class="about-float-card afc-meta"><div class="afc-title">Certified</div><div class="afc-value">Meta Pro</div></div>
            </div>
        </div>
        <div class="reveal">
            <p class="section-label">About Me</p>
            <h2 class="section-title">Driving Growth Through<br>Paid Social Strategy</h2>
            <p class="about-text">I'm a Senior Paid Social Executive at WPP Media, based in Warsaw, Poland, with 4+ years of expertise in paid social advertising.</p>
            <p class="about-text">Managing $350K–$550K monthly budgets across international markets, I excel at A/B testing, audience segmentation, and cross-functional collaboration.</p>
            <div class="about-details">
                <div class="about-detail"><div class="about-detail-label">Location</div><div class="about-detail-value">🇵🇱 Warsaw, Poland</div></div>
                <div class="about-detail"><div class="about-detail-label">Education</div><div class="about-detail-value">🎓 BSc Marketing</div></div>
                <div class="about-detail"><div class="about-detail-label">Role</div><div class="about-detail-value">📊 Sr. Paid Social</div></div>
                <div class="about-detail"><div class="about-detail-label">Company</div><div class="about-detail-value">🏢 WPP Media</div></div>
            </div>
            <div class="languages">
                <div class="lang-badge"><span class="lang-level native"></span> Uzbek</div>
                <div class="lang-badge"><span class="lang-level professional"></span> English</div>
                <div class="lang-badge"><span class="lang-level professional"></span> Russian</div>
                <div class="lang-badge"><span class="lang-level elementary"></span> Polish</div>
            </div>
        </div>
    </section>

    <section class="expertise" id="expertise">
        <div class="expertise-header reveal"><p class="section-label">What I Do</p><h2 class="section-title">Core Expertise</h2><p class="section-subtitle">Specialized skills over 4+ years of performance marketing</p></div>
        <div class="expertise-grid">
            <div class="expertise-card reveal reveal-delay-1"><div class="expertise-icon ei-1"><img src="https://cdn.simpleicons.org/meta/0081FB" width="28" height="28" alt="" onerror="this.parentElement.textContent='🎯'"></div><h3 class="expertise-title">Paid Social Strategy</h3><p class="expertise-desc">End-to-end campaign strategy across Meta, Snapchat, Pinterest, and Reddit platforms.</p></div>
            <div class="expertise-card reveal reveal-delay-2"><div class="expertise-icon ei-2"><img src="https://cdn.simpleicons.org/googleanalytics/E37400" width="28" height="28" alt="" onerror="this.parentElement.textContent='💰'"></div><h3 class="expertise-title">Budget Management</h3><p class="expertise-desc">Managing $350K–$550K monthly budgets with precision and ROI maximization.</p></div>
            <div class="expertise-card reveal reveal-delay-3"><div class="expertise-icon ei-3"><img src="https://cdn.simpleicons.org/googleads/4285F4" width="28" height="28" alt="" onerror="this.parentElement.textContent='🧪'"></div><h3 class="expertise-title">A/B Testing &amp; Analysis</h3><p class="expertise-desc">Rigorous testing for creative, audiences, and bidding strategies.</p></div>
            <div class="expertise-card reveal reveal-delay-1"><div class="expertise-icon ei-4"><img src="https://cdn.simpleicons.org/instagram/E4405F" width="28" height="28" alt="" onerror="this.parentElement.textContent='👥'"></div><h3 class="expertise-title">Audience Targeting</h3><p class="expertise-desc">Custom audiences, lookalikes, retargeting funnels, and segmentation.</p></div>
            <div class="expertise-card reveal reveal-delay-2"><div class="expertise-icon ei-5"><img src="https://cdn.simpleicons.org/tiktok/ffffff" width="28" height="28" alt="" onerror="this.parentElement.textContent='🎨'"></div><h3 class="expertise-title">Creative Optimization</h3><p class="expertise-desc">Testing ad formats and recommending optimizations based on data.</p></div>
            <div class="expertise-card reveal reveal-delay-3"><div class="expertise-icon ei-6"><img src="https://img.icons8.com/color/48/tableau-software.png" width="28" height="28" alt="Tableau" onerror="this.parentElement.textContent='📊'"></div><h3 class="expertise-title">Performance Reporting</h3><p class="expertise-desc">Comprehensive reporting using Tableau and platform analytics. Translating data into insights.</p></div>
        </div>
    </section>

    <section class="metrics-section" id="metrics">
        <div class="metrics-header reveal"><p class="section-label">Performance</p><h2 class="section-title">Campaign Metrics</h2></div>
        <div class="viz-container reveal">
            <div class="chart-card"><div class="chart-card-header"><div class="chart-card-title"><span class="live-dot"></span> Budget Trajectory ($K)</div></div><canvas id="budget-chart"></canvas></div>
            <div class="metrics-stack">
                <div class="metric-card"><div class="metric-label">Monthly Budget</div><div class="metric-value" style="color:var(--accent)">$550K+</div><div class="metric-change">↑ Scaled</div></div>
                <div class="metric-card"><div class="metric-label">Platforms</div><div class="metric-value" style="color:var(--secondary)">6+</div><div class="metric-change neutral">Meta, Snap, Pinterest...</div></div>
                <div class="metric-card"><div class="metric-label">Markets</div><div class="metric-value" style="color:var(--success)">INTL</div><div class="metric-change neutral">Multi-region</div></div>
                <div class="metric-card"><div class="metric-label">Campaigns</div><div class="metric-value" style="color:var(--warning)">500+</div><div class="metric-change">↑ All platforms</div></div>
            </div>
        </div>
    </section>

    <section class="experience" id="experience">
        <div class="experience-header reveal"><p class="section-label">Career</p><h2 class="section-title">Professional Experience</h2></div>
        <div class="timeline">
            <div class="timeline-item"><div class="timeline-dot"></div><div class="timeline-card"><p class="timeline-date">DEC 2025 — PRESENT</p><h3 class="timeline-role">Senior Paid Social Executive</h3><p class="timeline-company">WPP Media</p><p class="timeline-location">📍 Warsaw, Poland</p><ul class="timeline-details"><li>Leading paid social across multiple platforms</li><li>Managing $350K–$550K monthly budgets</li><li>A/B testing and data analysis for ROI</li></ul><div class="timeline-tools"><span class="tool-tag">Meta</span><span class="tool-tag">Snapchat</span><span class="tool-tag">Pinterest</span><span class="tool-tag">Reddit</span></div></div></div>
            <div class="timeline-item"><div class="timeline-dot"></div><div class="timeline-card"><p class="timeline-date">MAR 2023 — DEC 2023</p><h3 class="timeline-role">Media Operations Specialist</h3><p class="timeline-company">Groupon</p><p class="timeline-location">📍 Warsaw, Poland</p><ul class="timeline-details"><li>Meta campaigns creation &amp; management (INTL)</li><li>Performance reporting &amp; budget management</li><li>Creative coordination &amp; testing</li></ul><div class="timeline-tools"><span class="tool-tag">Meta Suite</span><span class="tool-tag">Tableau</span><span class="tool-tag">Workspace</span></div></div></div>
            <div class="timeline-item"><div class="timeline-dot"></div><div class="timeline-card"><p class="timeline-date">JUL 2022 — SEP 2022</p><h3 class="timeline-role">Jr. Marketing &amp; Media Manager</h3><p class="timeline-company">PROLEAGION GmbH</p><p class="timeline-location">📍 Wiesbaden, Germany</p><ul class="timeline-details"><li>Digital Media Buying (display, social, programmatic)</li><li>Campaign planning &amp; optimization</li></ul><div class="timeline-tools"><span class="tool-tag">Display</span><span class="tool-tag">Programmatic</span><span class="tool-tag">Social</span></div></div></div>
            <div class="timeline-item"><div class="timeline-dot"></div><div class="timeline-card"><p class="timeline-date">OCT 2021 — MAR 2022</p><h3 class="timeline-role">Social Media Marketing Specialist</h3><p class="timeline-company">Upwork (Freelance)</p><p class="timeline-location">📍 Warsaw, Poland</p><ul class="timeline-details"><li>Custom audiences on FB/IG/TikTok</li><li>B2C Lead Gen &amp; Retargeting</li></ul><div class="timeline-tools"><span class="tool-tag">Facebook</span><span class="tool-tag">Instagram</span><span class="tool-tag">TikTok</span></div></div></div>
            <div class="timeline-item"><div class="timeline-dot"></div><div class="timeline-card"><p class="timeline-date">JUN 2021 — SEP 2021</p><h3 class="timeline-role">FB &amp; IG Ads Specialist</h3><p class="timeline-company">Mars IT / Cambridge LC</p><p class="timeline-location">📍 Tashkent, Uzbekistan</p><ul class="timeline-details"><li>Lookalike campaigns &amp; A/B testing</li><li>Pixel setup &amp; retargeting</li></ul><div class="timeline-tools"><span class="tool-tag">Facebook</span><span class="tool-tag">Instagram</span></div></div></div>
        </div>
    </section>

    <section class="certifications" id="certifications">
        <div class="certs-header reveal"><p class="section-label">Credentials</p><h2 class="section-title">Certifications &amp; Awards</h2></div>
        <div class="certs-grid">
            <div class="cert-card award reveal"><div class="cert-icon ei-1"><img src="https://cdn.simpleicons.org/meta/0081FB" width="28" height="28" alt="" onerror="this.parentElement.textContent='🏆'"></div><div class="cert-info"><h4>Meta Certified Media Buying Professional</h4><p>Official Meta Certification</p><div class="cert-badge" style="background:rgba(255,165,0,0.1);color:var(--warning)">★ Honor Award</div></div></div>
            <div class="cert-card reveal"><div class="cert-icon ei-2"><img src="https://cdn.simpleicons.org/pinterest/BD081C" width="28" height="28" alt="" onerror="this.parentElement.textContent='📌'"></div><div class="cert-info"><h4>Pinterest Media Buyer Certification</h4><p>Pinterest Advertising</p><div class="cert-badge">✓ Verified</div></div></div>
            <div class="cert-card reveal"><div class="cert-icon ei-5"><img src="https://cdn.simpleicons.org/snapchat/FFFC00" width="28" height="28" alt="" onerror="this.parentElement.textContent='👻'"></div><div class="cert-info"><h4>Snapchat Essentials Certification</h4><p>Snapchat Advertising</p><div class="cert-badge">✓ Verified</div></div></div>
            <div class="cert-card reveal"><div class="cert-icon" style="background:rgba(255,69,0,0.1)"><img src="https://cdn.simpleicons.org/reddit/FF4500" width="28" height="28" alt="" onerror="this.parentElement.textContent='🤖'"></div><div class="cert-info"><h4>Reddit Ads Boost Certification</h4><p>Reddit Advertising</p><div class="cert-badge">✓ Verified</div></div></div>
            <div class="cert-card reveal"><div class="cert-icon ei-3"><img src="https://cdn.simpleicons.org/google/4285F4" width="28" height="28" alt="" onerror="this.parentElement.textContent='🔍'"></div><div class="cert-info"><h4>Google Ads (Adwords) Masterclass</h4><p>PPC Advertising</p><div class="cert-badge">✓ Verified</div></div></div>
            <div class="cert-card reveal"><div class="cert-icon ei-6"><img src="https://cdn.simpleicons.org/facebook/1877F2" width="28" height="28" alt="" onerror="this.parentElement.textContent='📘'"></div><div class="cert-info"><h4>Facebook Ads Certification</h4><p>Meta – Facebook Advertising</p><div class="cert-badge">✓ Verified</div></div></div>
        </div>
    </section>

    <section class="contact" id="contact">
        <div class="reveal"><p class="section-label">Get In Touch</p><h2 class="section-title">Let's Work Together</h2></div>
        <p class="contact-description reveal">Looking for a paid social expert to scale your campaigns? Let's talk.</p>
        <a href="mailto:rrasulbekr@gmail.com" class="contact-email-link reveal"><span class="contact-email">rrasulbekr@gmail.com</span></a>
        <div class="social-links reveal">
            <a href="https://www.linkedin.com/in/rasulbek-rustamov/" target="_blank" class="social-link"><svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg></a>
            <a href="https://t.me/rasulbekrustamov" target="_blank" class="social-link"><svg viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"></path></svg></a>
            <a href="mailto:rrasulbekr@gmail.com" class="social-link"><svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path></svg></a>
        </div>
    </section>

    <footer><p>© 2026 Rasulbek Rustamov</p><p>Warsaw 🇵🇱</p></footer>

    <script>
        const canvas=document.getElementById('bg-canvas'),ctx=canvas.getContext('2d');let particles=[],mousePos={x:null,y:null};function resizeCanvas(){canvas.width=window.innerWidth;canvas.height=window.innerHeight}resizeCanvas();window.addEventListener('resize',()=>{resizeCanvas();initP()});class P{constructor(){this.x=Math.random()*canvas.width;this.y=Math.random()*canvas.height;this.s=Math.random()*1.5+.5;this.vx=(Math.random()-.5)*.3;this.vy=(Math.random()-.5)*.3;this.o=Math.random()*.3+.1}update(){this.x+=this.vx;this.y+=this.vy;if(this.x<0||this.x>canvas.width)this.vx*=-1;if(this.y<0||this.y>canvas.height)this.vy*=-1;if(mousePos.x!==null){let dx=mousePos.x-this.x,dy=mousePos.y-this.y,d=Math.sqrt(dx*dx+dy*dy);if(d<100){this.x-=dx*.008;this.y-=dy*.008}}}draw(){ctx.beginPath();ctx.arc(this.x,this.y,this.s,0,Math.PI*2);ctx.fillStyle=`rgba(67,97,238,${this.o})`;ctx.fill()}}function initP(){particles=[];for(let i=0;i<Math.min(Math.floor(window.innerWidth*.05),70);i++)particles.push(new P)}initP();function anim(){ctx.clearRect(0,0,canvas.width,canvas.height);particles.forEach(p=>{p.update();p.draw()});for(let i=0;i<particles.length;i++)for(let j=i+1;j<particles.length;j++){let dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<110){ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.strokeStyle=`rgba(67,97,238,${(110-d)/110*.08})`;ctx.lineWidth=.5;ctx.stroke()}}requestAnimationFrame(anim)}anim();

        (function(){const c=document.getElementById('hero-chart');if(!c)return;const cx=c.getContext('2d');c.width=420;c.height=420;const skills=[{name:'Meta Ads',value:.95,color:'#4361ee'},{name:'Snapchat',value:.85,color:'#f72585'},{name:'Pinterest',value:.80,color:'#4cc9f0'},{name:'Strategy',value:.92,color:'#00c896'},{name:'Analytics',value:.88,color:'#ffa500'},{name:'Budget',value:.93,color:'#7209b7'}];let prog=0,time=0;const X=210,Y=210,R=160,A=Math.PI*2/6;function draw(){cx.clearRect(0,0,420,420);if(prog<1)prog+=.012;time+=.015;const e=1-Math.pow(1-Math.min(prog,1),3);for(let i=1;i<=5;i++){cx.beginPath();cx.arc(X,Y,(R/5)*i,0,Math.PI*2);cx.strokeStyle='rgba(255,255,255,0.04)';cx.stroke()}skills.forEach((_,i)=>{const a=A*i-Math.PI/2;cx.beginPath();cx.moveTo(X,Y);cx.lineTo(X+Math.cos(a)*R,Y+Math.sin(a)*R);cx.strokeStyle='rgba(255,255,255,0.04)';cx.stroke()});cx.beginPath();skills.forEach((s,i)=>{const a=A*i-Math.PI/2,p=1+Math.sin(time*2+i)*.015,r=R*s.value*e*p,x=X+Math.cos(a)*r,y=Y+Math.sin(a)*r;i===0?cx.moveTo(x,y):cx.lineTo(x,y)});cx.closePath();cx.fillStyle='rgba(67,97,238,0.1)';cx.fill();cx.strokeStyle='rgba(67,97,238,0.5)';cx.lineWidth=2;cx.stroke();skills.forEach((s,i)=>{const a=A*i-Math.PI/2,p=1+Math.sin(time*2+i)*.015,r=R*s.value*e*p,x=X+Math.cos(a)*r,y=Y+Math.sin(a)*r;cx.beginPath();cx.arc(x,y,4,0,Math.PI*2);cx.fillStyle=s.color;cx.fill();cx.fillStyle='rgba(255,255,255,0.6)';cx.font='11px Inter';cx.textAlign='center';cx.fillText(s.name,X+Math.cos(a)*(R+28),Y+Math.sin(a)*(R+28));cx.fillStyle=s.color;cx.font='600 10px Space Grotesk';cx.fillText(Math.round(s.value*100)+'%',X+Math.cos(a)*(R+43),Y+Math.sin(a)*(R+43))});cx.fillStyle='rgba(255,255,255,0.85)';cx.font='700 16px Space Grotesk';cx.textAlign='center';cx.fillText('Skills',X,Y-6);cx.fillStyle='rgba(255,255,255,0.35)';cx.font='11px Inter';cx.fillText('Overview',X,Y+12);requestAnimationFrame(draw)}setTimeout(draw,800)})();

        (function(){const c=document.getElementById('budget-chart');if(!c)return;const cx=c.getContext('2d');let started=false;c.width=c.parentElement.clientWidth-70;c.height=220;const data=[150,200,250,280,320,350,380,420,450,480,520,550],m=['J','F','M','A','M','J','J','A','S','O','N','D'],p={top:20,right:15,bottom:30,left:45},max=600;let a=0;function draw(){const W=c.width-p.left-p.right,H=c.height-p.top-p.bottom;cx.clearRect(0,0,c.width,c.height);if(a<1)a+=.016;const e=1-Math.pow(1-Math.min(a,1),3);for(let i=0;i<=4;i++){const y=p.top+(H/4)*i;cx.beginPath();cx.moveTo(p.left,y);cx.lineTo(c.width-p.right,y);cx.strokeStyle='rgba(255,255,255,0.04)';cx.stroke();cx.fillStyle='rgba(255,255,255,0.3)';cx.font='10px Inter';cx.textAlign='right';cx.textBaseline='middle';cx.fillText('$'+(max-(max/4)*i)+'K',p.left-8,y)}data.forEach((_,i)=>{cx.fillStyle='rgba(255,255,255,0.3)';cx.font='10px Inter';cx.textAlign='center';cx.textBaseline='top';cx.fillText(m[i],p.left+(W/11)*i,c.height-12)});const g=cx.createLinearGradient(0,p.top,0,p.top+H);g.addColorStop(0,'rgba(67,97,238,0.25)');g.addColorStop(1,'rgba(67,97,238,0)');const n=Math.ceil(12*e);cx.beginPath();cx.moveTo(p.left,p.top+H);for(let i=0;i<n;i++){const x=p.left+(W/11)*i,y=p.top+H-(data[i]/max)*H*e;if(i===0)cx.lineTo(x,y);else{const px=p.left+(W/11)*(i-1),py=p.top+H-(data[i-1]/max)*H*e;cx.bezierCurveTo((px+x)/2,py,(px+x)/2,y,x,y)}}cx.lineTo(p.left+(W/11)*(n-1),p.top+H);cx.closePath();cx.fillStyle=g;cx.fill();cx.beginPath();for(let i=0;i<n;i++){const x=p.left+(W/11)*i,y=p.top+H-(data[i]/max)*H*e;if(i===0)cx.moveTo(x,y);else{const px=p.left+(W/11)*(i-1),py=p.top+H-(data[i-1]/max)*H*e;cx.bezierCurveTo((px+x)/2,py,(px+x)/2,y,x,y)}}cx.strokeStyle='#4361ee';cx.lineWidth=2.5;cx.stroke();for(let i=0;i<n;i++){const x=p.left+(W/11)*i,y=p.top+H-(data[i]/max)*H*e;cx.beginPath();cx.arc(x,y,4,0,Math.PI*2);cx.fillStyle='#4361ee';cx.fill();cx.beginPath();cx.arc(x,y,2,0,Math.PI*2);cx.fillStyle='#fff';cx.fill()}if(a<1)requestAnimationFrame(draw)}const obs=new IntersectionObserver(e=>{if(e[0].isIntersecting&&!started){started=true;draw();obs.disconnect()}},{threshold:.3});obs.observe(c)})();

        if(window.innerWidth>768){const dot=document.getElementById('cursorDot'),ring=document.getElementById('cursorRing');document.addEventListener('mousemove',e=>{dot.style.left=e.clientX+'px';dot.style.top=e.clientY+'px';ring.style.left=e.clientX+'px';ring.style.top=e.clientY+'px';mousePos.x=e.clientX;mousePos.y=e.clientY});document.addEventListener('mouseleave',()=>{dot.style.opacity='0';ring.style.opacity='0';mousePos.x=null;mousePos.y=null});document.addEventListener('mouseenter',()=>{dot.style.opacity='1';ring.style.opacity='1'});document.querySelectorAll('a,button,.btn,.expertise-card,.cert-card,.social-link,.metric-card,.hamburger,.about-detail,.marquee-item,.logo,.about-photo-wrapper').forEach(el=>{el.addEventListener('mouseenter',()=>ring.classList.add('hover'));el.addEventListener('mouseleave',()=>ring.classList.remove('hover'))})}

        const navEl=document.getElementById('navbar'),allNav=document.querySelectorAll('.nav-link'),allSec=document.querySelectorAll('section[id]');function onScroll(){const s=window.scrollY,d=document.documentElement.scrollHeight-window.innerHeight;document.getElementById('scrollProgress').style.width=(d>0?(s/d)*100:0)+'%';navEl.classList.toggle('scrolled',s>50);let cur='home';allSec.forEach(sec=>{if(s>=sec.offsetTop-150)cur=sec.id});allNav.forEach(l=>{l.classList.remove('active');if(l.getAttribute('href')==='#'+cur)l.classList.add('active')})}window.addEventListener('scroll',onScroll,{passive:true});onScroll();
        document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t){window.scrollTo({top:t.offsetTop-80,behavior:'smooth'});document.getElementById('navLinks').classList.remove('active');document.getElementById('hamburger').classList.remove('active');document.getElementById('navOverlay').classList.remove('active')}})});

        const ham=document.getElementById('hamburger'),navL=document.getElementById('navLinks'),navO=document.getElementById('navOverlay');ham.addEventListener('click',()=>{ham.classList.toggle('active');navL.classList.toggle('active');navO.classList.toggle('active')});navO.addEventListener('click',()=>{ham.classList.remove('active');navL.classList.remove('active');navO.classList.remove('active')});

        document.querySelectorAll('.reveal,.timeline-item').forEach(el=>{new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:.1,rootMargin:'0px 0px -40px 0px'}).observe(el)});
    </script>

</body></html>
